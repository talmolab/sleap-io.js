{
  "name": "@talmolab/sleap-io.js",
  "version": "0.3.1",
  "private": false,
  "type": "module",
  "exports": {
    ".": {
      "browser": {
        "types": "./dist/index.browser.d.ts",
        "import": "./dist/index.browser.js"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./lite": {
      "types": "./dist/lite.d.ts",
      "import": "./dist/lite.js"
    }
  },
  "main": "./dist/index.js",
  "browser": "./dist/index.browser.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/talmolab/sleap-io.js.git"
  },
  "scripts": {
    "build": "tsup src/index.ts src/index.browser.ts src/lite.ts --format esm --dts --external skia-canvas --external mediabunny",
    "test": "bun test --parallel",
    "test:coverage": "bun test --parallel --coverage",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "h5wasm": "^0.10.2",
    "jsfive": "^0.3.10",
    "mediabunny": "^1.30.0",
    "mp4box": "^0.5.4",
    "pako": "^2.1.0",
    "yaml": "^2.6.1"
  },
  "optionalDependencies": {
    "skia-canvas": "^3.0.8"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^22.10.5",
    "@types/pako": "^2.0.4",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  },
  "trustedDependencies": [
    "esbuild",
    "skia-canvas"
  ],
  "packageManager": "bun@1.3.14"
}
